{
  "name": "kovaaks-progression-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri": "tauri",
    "windows:dev": "tauri dev --features desktop",
    "windows:build": "tauri build --features desktop",
    "windows:cargo-build": "cargo build --release --features desktop --manifest-path src-tauri/Cargo.toml",
    "windows:portable": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows-portable.ps1",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:ui": "vitest --environment jsdom",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.76.1",
    "@tanstack/react-router": "^1.120.0",
    "@tauri-apps/api": "^2.5.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tauri-apps/cli": "^2.5.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.2"
  }
}
