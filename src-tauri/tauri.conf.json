{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kovaak's Progression Tracker",
  "version": "0.1.0",
  "identifier": "local.kovaaks.progression-tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "features": ["desktop"]
  },
  "app": {
    "windows": [
      {
        "title": "Kovaak's Progression Tracker",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"]
  }
}
